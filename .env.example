# Copy this to .env.local and fill in your values
# Get DATABASE_URL from neon.tech (free account)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/devfolio?sslmode=require

# Generate a random secret: run -> node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_here_change_this

# Admin credentials (you can change these)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
